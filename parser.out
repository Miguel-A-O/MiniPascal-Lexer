Rule 26    procedure_declaration -> PROCEDURE ID LPAREN args RPAREN SEMICOLON compound_stmt SEMICOLON
Rule 27    function_declaration -> FUNCTION ID LPAREN args RPAREN COLON type_specifier SEMICOLON compound_stmt SEMICOLON
Rule 28    compound_stmt -> BEGIN statement_list END
Rule 29    statement_list -> statement_list statement
Rule 30    statement_list -> statement
Rule 31    if_stmt -> IF LPAREN expression RPAREN THEN statement
Rule 32    if_stmt -> IF LPAREN expression RPAREN THEN statement ELSE statement
Rule 33    statement -> call_stmt SEMICOLON
Rule 34    statement -> assignment_stmt SEMICOLON
Rule 35    statement -> compound_stmt
Rule 36    statement -> if_stmt
Rule 37    statement -> empty
Rule 38    call_stmt -> ID LPAREN args RPAREN
Rule 39    call_stmt -> ID
Rule 40    args -> expression_list
Rule 41    args -> empty
Rule 42    expression_list -> expression_list COMMA expression
Rule 43    expression_list -> expression
Rule 44    assignment_stmt -> ID ASSIGN expression
Rule 45    expression_formatted -> expression COLON type_specifier
Rule 46    expression -> term
Rule 47    expression -> expression PLUS term
Rule 48    expression -> expression MINUS term
Rule 49    expression -> expression TIMES term
Rule 50    expression -> expression DIVIDE term
Rule 51    expression -> expression GREATER term
